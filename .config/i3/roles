# vim: ft=i3config

for_window [class="^Nitrogen|Xfce4-settings-editor|Lxappearance$"] floating enable
for_window [class="^Nitrogen|Xfce4-settings-editor|Lxappearance$"] resize set 1720 1200
for_window [instance="floating-editor"] floating enable, resize set 800 600, move position center
